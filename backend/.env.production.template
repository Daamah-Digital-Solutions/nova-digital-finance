# =============================================================================
# NOVA DIGITAL FINANCE - PRODUCTION ENVIRONMENT CONFIGURATION
# =============================================================================
# INSTRUCTIONS:
# 1. Copy this file to .env.production
# 2. Replace ALL placeholder values with your actual production credentials
# 3. NEVER commit .env.production to version control
# =============================================================================

# -----------------------------------------------------------------------------
# DJANGO CORE SETTINGS
# -----------------------------------------------------------------------------
DJANGO_ENV=production
DEBUG=false

# Generate a new secret key with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=<GENERATE_NEW_SECRET_KEY>

# Your production domains (comma-separated, no spaces)
ALLOWED_HOSTS=novadf.com,www.novadf.com

# Frontend URL for CORS
CORS_ALLOWED_ORIGINS=https://novadf.com,https://www.novadf.com

# -----------------------------------------------------------------------------
# DATABASE CONFIGURATION (PostgreSQL)
# -----------------------------------------------------------------------------
DB_NAME=nova_finance_prod
DB_USER=nova_prod_user
DB_PASSWORD=<STRONG_DATABASE_PASSWORD>
DB_HOST=localhost
DB_PORT=5432

# -----------------------------------------------------------------------------
# REDIS CONFIGURATION
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=<STRONG_REDIS_PASSWORD>

# -----------------------------------------------------------------------------
# EMAIL CONFIGURATION (SMTP)
# -----------------------------------------------------------------------------
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=<YOUR_SMTP_HOST>
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=<YOUR_EMAIL_ADDRESS>
EMAIL_HOST_PASSWORD=<YOUR_EMAIL_PASSWORD>
DEFAULT_FROM_EMAIL=Nova Digital Finance <noreply@novadf.com>

# -----------------------------------------------------------------------------
# STRIPE PAYMENT PROCESSING (LIVE KEYS)
# -----------------------------------------------------------------------------
# Get these from: https://dashboard.stripe.com/apikeys
STRIPE_PUBLISHABLE_KEY=<YOUR_STRIPE_LIVE_PUBLISHABLE_KEY>
STRIPE_SECRET_KEY=<YOUR_STRIPE_LIVE_SECRET_KEY>

# Get this from: https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=<YOUR_STRIPE_WEBHOOK_SECRET>

# -----------------------------------------------------------------------------
# SECURITY SETTINGS (All must be true for production)
# -----------------------------------------------------------------------------
SESSION_COOKIE_SECURE=true
CSRF_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true
CSRF_COOKIE_HTTPONLY=true
SECURE_SSL_REDIRECT=true
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=true
SECURE_HSTS_PRELOAD=true
SECURE_CONTENT_TYPE_NOSNIFF=true
SECURE_BROWSER_XSS_FILTER=true
X_FRAME_OPTIONS=DENY

# -----------------------------------------------------------------------------
# JWT AUTHENTICATION
# -----------------------------------------------------------------------------
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=<GENERATE_NEW_JWT_SECRET>
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# -----------------------------------------------------------------------------
# ENCRYPTION
# -----------------------------------------------------------------------------
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECURITY_KEY_ENCRYPTION=<GENERATE_32_CHAR_HEX_KEY>

# -----------------------------------------------------------------------------
# RATE LIMITING (Strict for production)
# -----------------------------------------------------------------------------
RATE_LIMIT_PER_MINUTE=60
AUTH_RATE_LIMIT_PER_MINUTE=5

# -----------------------------------------------------------------------------
# PRODUCTION URLS
# -----------------------------------------------------------------------------
FRONTEND_URL=https://novadf.com
BACKEND_URL=https://novadf.com/api

# -----------------------------------------------------------------------------
# EXTERNAL API INTEGRATIONS
# -----------------------------------------------------------------------------
CAPIMAX_API_URL=<CAPIMAX_PRODUCTION_API_URL>
CAPIMAX_API_KEY=<CAPIMAX_PRODUCTION_API_KEY>

MHCC_API_URL=<MHCC_PRODUCTION_API_URL>
MHCC_API_KEY=<MHCC_PRODUCTION_API_KEY>

# -----------------------------------------------------------------------------
# MONITORING
# -----------------------------------------------------------------------------
GRAFANA_ADMIN_PASSWORD=<STRONG_GRAFANA_PASSWORD>
ELASTICSEARCH_PASSWORD=<STRONG_ELASTICSEARCH_PASSWORD>

# -----------------------------------------------------------------------------
# SUPERUSER (Change immediately after first login)
# -----------------------------------------------------------------------------
CREATE_SUPERUSER=true
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=<YOUR_ADMIN_EMAIL>
DJANGO_SUPERUSER_PASSWORD=<VERY_STRONG_ADMIN_PASSWORD>
