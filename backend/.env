# Nova Finance Environment Configuration
# For testing - replace with real values when ready

# Django Settings
SECRET_KEY=django-insecure-test-key-replace-in-production
DEBUG=True
DEPLOYMENT_ENVIRONMENT=development

# Database - Using SQLite for testing
DATABASE_URL=sqlite:///nova_finance.db

# Stripe Configuration - For Testing
# Set STRIPE_ENABLED=True when you have real API keys
STRIPE_ENABLED=False
STRIPE_PUBLISHABLE_KEY=pk_test_placeholder_key
STRIPE_SECRET_KEY=sk_test_placeholder_key
STRIPE_WEBHOOK_SECRET=

# Email Configuration (Optional for testing)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# Security Settings - Disabled for local testing
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0

# Encryption
ENCRYPTION_KEY_PATH=encryption.key

# MHCC Integration (Optional)
MHCC_API_URL=https://api.mhcc.security
MHCC_API_KEY=
MHCC_CLIENT_ID=nova-finance
MHCC_MONITORING_ENABLED=False

# Cache
REDIS_URL=redis://127.0.0.1:6379/1