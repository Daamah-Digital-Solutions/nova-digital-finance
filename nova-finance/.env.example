# Nova Finance Environment Configuration
# Copy this file to .env and fill in your actual values

# Django Settings
SECRET_KEY=your-super-secret-django-key-here-minimum-50-characters
DEBUG=false
ALLOWED_HOSTS=localhost,127.0.0.1,nova-finance.com,www.nova-finance.com
CORS_ALLOWED_ORIGINS=https://nova-finance.com,https://www.nova-finance.com

# Database Configuration
DB_NAME=nova_finance
DB_USER=nova_user
DB_PASSWORD=your-secure-database-password-here
DB_HOST=postgres
DB_PORT=5432

# Redis Configuration
REDIS_PASSWORD=your-secure-redis-password-here

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=noreply@nova-finance.com
EMAIL_HOST_PASSWORD=your-email-app-password-here
DEFAULT_FROM_EMAIL=Nova Finance <noreply@nova-finance.com>

# Payment Processing (Stripe)
STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_publishable_key
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key

# External API Integrations
CAPIMAX_API_URL=https://api.capimax.com
CAPIMAX_API_KEY=your-capimax-api-key-here

# MHCC Cybersecurity Integration
MHCC_API_URL=https://api.mhcc-cyber.com
MHCC_API_KEY=your-mhcc-api-key-here

# Superuser Creation (for initial setup)
CREATE_SUPERUSER=true
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@nova-finance.com
DJANGO_SUPERUSER_PASSWORD=your-secure-admin-password-here

# Monitoring & Analytics
GRAFANA_ADMIN_PASSWORD=your-secure-grafana-password-here

# SSL Certificate Configuration
SSL_CERT_PATH=/etc/nginx/ssl/nova-finance.crt
SSL_KEY_PATH=/etc/nginx/ssl/nova-finance.key

# Security Configuration
SECURITY_KEY_ENCRYPTION=your-32-character-encryption-key
JWT_SECRET_KEY=your-jwt-secret-key-here

# External Services
GOOGLE_MAPS_API_KEY=your-google-maps-api-key
RECAPTCHA_SITE_KEY=your-recaptcha-site-key
RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key

# Backup Configuration
BACKUP_STORAGE_TYPE=s3
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_STORAGE_BUCKET_NAME=nova-finance-backups

# CDN Configuration (optional)
AWS_CLOUDFRONT_DOMAIN=cdn.nova-finance.com

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100
AUTH_RATE_LIMIT_PER_MINUTE=5

# Session Security
SESSION_COOKIE_SECURE=true
CSRF_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true
CSRF_COOKIE_HTTPONLY=true

# Production URLs
FRONTEND_URL=https://nova-finance.com
BACKEND_URL=https://api.nova-finance.com