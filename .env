# Nova Finance Development Environment Configuration

# Django Settings
SECRET_KEY=django-insecure-dev-key-only-for-development-12345678901234567890
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Database Configuration
DB_NAME=nova_finance
DB_USER=nova_user
DB_PASSWORD=nova_password_123
DB_HOST=postgres
DB_PORT=5432

# Redis Configuration
REDIS_PASSWORD=redis_password_123

# Email Configuration (Development - Console backend)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=dev@nova-finance.com
EMAIL_HOST_PASSWORD=dev-email-password
DEFAULT_FROM_EMAIL=Nova Finance Dev <dev@nova-finance.com>

# Payment Processing (Stripe Test Keys)
STRIPE_PUBLISHABLE_KEY=pk_test_development_key_here
STRIPE_SECRET_KEY=sk_test_development_key_here

# External API Integrations (Development)
CAPIMAX_API_URL=https://api-dev.capimax.com
CAPIMAX_API_KEY=dev-capimax-api-key

# MHCC Cybersecurity Integration (Development)
MHCC_API_URL=https://api-dev.mhcc-cyber.com
MHCC_API_KEY=dev-mhcc-api-key

# Superuser Creation (for development)
CREATE_SUPERUSER=true
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@nova-finance.com
DJANGO_SUPERUSER_PASSWORD=admin123

# Monitoring & Analytics
GRAFANA_ADMIN_PASSWORD=grafana123

# Security Configuration (Development)
SECURITY_KEY_ENCRYPTION=development-encryption-key-32char
JWT_SECRET_KEY=jwt-secret-key-for-development

# External Services (Development)
GOOGLE_MAPS_API_KEY=dev-google-maps-key
RECAPTCHA_SITE_KEY=dev-recaptcha-site-key
RECAPTCHA_SECRET_KEY=dev-recaptcha-secret-key

# Rate Limiting (Relaxed for development)
RATE_LIMIT_PER_MINUTE=1000
AUTH_RATE_LIMIT_PER_MINUTE=50

# Session Security (Development)
SESSION_COOKIE_SECURE=false
CSRF_COOKIE_SECURE=false
SESSION_COOKIE_HTTPONLY=true
CSRF_COOKIE_HTTPONLY=true
SECURE_SSL_REDIRECT=false

# Development URLs
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# Additional Development Settings
ELASTICSEARCH_PASSWORD=elastic123
GRAFANA_SECRET_KEY=grafana-secret-key-development